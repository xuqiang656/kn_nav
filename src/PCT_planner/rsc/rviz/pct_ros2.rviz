      Decay Time: 0
      Enabled: true
      Invert Rainbow: true
      Max Color: 255; 50; 50
      Max Intensity: 60
      Min Color: 50; 255; 50
      Min Intensity: -20
      Name: Tomogram (traversability)
      Position Transformer: XYZ
      Selectable: true
      Size (Pixels): 3
