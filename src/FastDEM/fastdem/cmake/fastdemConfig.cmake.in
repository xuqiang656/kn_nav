@PACKAGE_INIT@

include(CMakeFindDependencyMacro)
find_dependency(Eigen3)
find_dependency(yaml-cpp)
find_dependency(spdlog)
find_dependency(OpenMP)

# nanoGrid: find on system if it was not bundled at build time
if(@nanoGrid_FOUND@)
  find_dependency(nanoGrid)
endif()

include("${CMAKE_CURRENT_LIST_DIR}/fastdemTargets.cmake")

check_required_components(fastdem)
